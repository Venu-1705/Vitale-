# Mobile app — copy to .env and fill in. NEVER commit .env.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-publishable-anon-key

# API base. lib/api resolves to https://${EXPO_PUBLIC_DOMAIN}/api when set, else "/api".
# For local dev, point this at a host reachable from the device/simulator that
# serves the API over HTTPS (e.g. an ngrok/cloudflared tunnel to localhost:3000).
EXPO_PUBLIC_DOMAIN=your-api-host

# Leave DEMO_MODE unset for real auth. Set EXPO_PUBLIC_DEMO_MODE=true (or
# EXPO_PUBLIC_DEMO_USER_ID=<uuid>) only for offline demo against a demo backend.
