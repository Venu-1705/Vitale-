# API server — copy to .env and fill in. NEVER commit .env.
PORT=3000
NODE_ENV=development

# Auth: when DEMO_MODE!=true, every authed route requires a verified Supabase JWT.
DEMO_MODE=false

# Supabase is AUTHENTICATION-ONLY (it issues JWTs, incl. Google OAuth). It does NOT
# host the database — only token verification keys are read from it.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# HS256 legacy projects: the dashboard "JWT Secret" (used as the HMAC key).
SUPABASE_JWT_SECRET=your-legacy-hs256-jwt-secret
# Asymmetric (ES256/RS256) projects: the JWKS endpoint. Safe to set alongside the
# secret — identity.ts picks the key by the token's `alg` header.
SUPABASE_JWKS_URL=https://YOUR_PROJECT.supabase.co/auth/v1/.well-known/jwks.json
# Optional; NOT used for database access (the DB service_role is a local PG role).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LOCAL PostgreSQL. Used by migrations, seed, and the runtime pools. The login role
# must be a superuser/owner (bootstrap 0000 does CREATE ROLE / CREATE SCHEMA).
DATABASE_URL=postgresql://postgres@localhost:5432/vitale

# Cashfree Payment Gateway (server-side only — NEVER expose the secret to a client).
# Get these from the Cashfree dashboard. CASHFREE_ENV=TEST uses the SANDBOX
# environment; any other value uses PRODUCTION. The webhook is verified with the
# secret key, so it must match the environment the orders are created in.
CASHFREE_APP_ID=your-cashfree-app-id
CASHFREE_SECRET_KEY=your-cashfree-secret-key
CASHFREE_ENV=TEST

# Zoom (Server-to-Server OAuth app — server-side only; NEVER expose to the client).
# From the Zoom Marketplace S2S OAuth app: Account ID + the app's Client ID/Secret.
# Used to mint account-scoped tokens and create meetings for coaching sessions.
ZOOM_ACCOUNT_ID=your-zoom-account-id
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret
